# .gitignore para proyecto Python en macOS

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Translations
*.mo
*.pot

# pytest cache
.pytest_cache/

# Virtualenv
venv/
.env/
.venv/
env/
ENV/
env.bak/
venv.bak/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Audio / temporary files
*.wav
*.mp3
*.flac
*.tmp
*.temp

# Logs
*.log

# Local config containing secrets
.env

# Misc
.ipynb_checkpoints
*.sqlite3
*.db
